<%- include('../partials/header-user') %>
<div class="page-header">
  <h4><i class="fa-solid fa-id-card me-2 text-primary"></i>Thông tin của tôi</h4>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body p-4 text-center">
        <div class="user-avatar-lg"><%= user.fullName.charAt(0).toUpperCase() %></div>
        <h5 class="fw-bold mb-0"><%= user.fullName %></h5>
        <code class="text-muted"><%= user.username %></code>
        <% if (user.room) { %>
          <div class="mt-2"><span class="badge-occupied">Phòng <%= user.room.roomNumber %></span></div>
        <% } %>
      </div>
      <hr class="my-0"/>
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Họ và tên</label>
            <div class="form-control bg-light"><%= user.fullName %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Tên đăng nhập</label>
            <div class="form-control bg-light"><code><%= user.username %></code></div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Số điện thoại</label>
            <div class="form-control bg-light"><%= user.phone || '—' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Ngày sinh</label>
            <div class="form-control bg-light"><%= user.birthDate ? moment(user.birthDate).format('DD/MM/YYYY') : '—' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Số CCCD</label>
            <div class="form-control bg-light"><%= user.idCard || '—' %></div>
          </div>
          <div class="col-md-6">
            <label class="form-label">Phòng</label>
            <div class="form-control bg-light">
              <% if (user.room) { %>
                Phòng <%= user.room.roomNumber %> — <%= user.room.rentPrice?.toLocaleString('vi-VN') %>đ/tháng
              <% } else { %>Chưa có phòng<% } %>
            </div>
          </div>
        </div>
        <div class="mt-4">
          <a href="/user/change-password" class="btn btn-outline-primary">
            <i class="fa-solid fa-lock me-2"></i>Đổi mật khẩu
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
