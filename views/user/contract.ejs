<%- include('../partials/header-user') %>
<div class="page-header">
  <h4><i class="fa-solid fa-file-contract me-2 text-primary"></i>Hợp đồng thuê trọ</h4>
</div>

<% if (contract) { %>
<div class="invoice-box">
  <div class="text-center mb-4">
    <h5 class="fw-bold">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h5>
    <p class="text-muted small">Độc lập - Tự do - Hạnh phúc</p>
    <h5 class="fw-bold mt-3">HỢP ĐỒNG THUÊ NHÀ TRỌ</h5>
    <p class="text-muted small">Mã: <strong><%= contract.contractCode %></strong></p>
    <span class="badge-<%= contract.status %>">
      <%= contract.status === 'active' ? '✓ Đang hiệu lực' : contract.status === 'expired' ? 'Hết hạn' : 'Đã chấm dứt' %>
    </span>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">BÊN CHO THUÊ (A)</h6>
      <div class="small"><strong>Tên:</strong> <%= settings.landlordName || '—' %></div>
      <div class="small"><strong>SĐT:</strong> <%= settings.landlordPhone || '—' %></div>
      <div class="small"><strong>Địa chỉ:</strong> <%= settings.address || '—' %></div>
    </div>
    <div class="col-md-6">
      <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">BÊN THUÊ (B)</h6>
      <div class="small"><strong>Họ tên:</strong> <%= contract.user?.fullName %></div>
      <div class="small"><strong>SĐT:</strong> <%= contract.user?.phone || '—' %></div>
      <div class="small"><strong>CCCD:</strong> <%= contract.user?.idCard || '—' %></div>
    </div>
  </div>

  <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">THÔNG TIN PHÒNG & GIÁ THUÊ</h6>
  <div class="row g-2 small mb-4">
    <div class="col-6"><strong>Phòng số:</strong> <%= contract.room?.roomNumber %></div>
    <div class="col-6"><strong>Giá thuê:</strong> <%= contract.rentPrice.toLocaleString('vi-VN') %>đ/tháng</div>
    <div class="col-6"><strong>Ngày bắt đầu:</strong> <%= moment(contract.startDate).format('DD/MM/YYYY') %></div>
    <div class="col-6"><strong>Ngày kết thúc:</strong> <%= contract.endDate ? moment(contract.endDate).format('DD/MM/YYYY') : 'Không xác định' %></div>
    <div class="col-6"><strong>Tiền cọc:</strong> <%= contract.depositAmount.toLocaleString('vi-VN') %>đ</div>
  </div>

  <% if (contract.terms) { %>
  <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">ĐIỀU KHOẢN HỢP ĐỒNG</h6>
  <p class="small" style="white-space:pre-wrap"><%= contract.terms %></p>
  <% } %>

  <% if (contract.contractImage) { %>
  <div class="mt-3 p-3 bg-light rounded-3 d-flex align-items-center gap-3">
    <i class="fa-solid fa-image fa-2x text-primary"></i>
    <div>
      <div class="fw-semibold small">Ảnh hợp đồng đã được tải lên</div>
      <button class="btn btn-sm btn-primary mt-1" data-bs-toggle="modal" data-bs-target="#imageModal">
        <i class="fa-solid fa-eye me-1"></i>Xem ảnh hợp đồng
      </button>
    </div>
  </div>
  <% } %>

  <div class="d-flex gap-2 mt-4">
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">
      <i class="fa-solid fa-print me-1"></i>In hợp đồng
    </button>
  </div>
</div>

<!-- Modal xem ảnh hợp đồng -->
<% if (contract && contract.contractImage) { %>
<div class="modal fade" id="imageModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">
          <i class="fa-solid fa-image me-2 text-primary"></i>Ảnh hợp đồng — <%= contract.contractCode %>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-3">
        <img src="<%= contract.contractImage %>" class="img-fluid rounded-3" style="max-height:80vh; object-fit:contain;" alt="Ảnh hợp đồng"/>
      </div>
      <div class="modal-footer">
        <a href="<%= contract.contractImage %>" download class="btn btn-outline-primary">
          <i class="fa-solid fa-download me-1"></i>Tải xuống
        </a>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>
<% } %>

<% } else { %>
  <div class="text-center py-5 text-muted">
    <i class="fa-solid fa-file-circle-question fa-3x mb-3 d-block opacity-25"></i>
    Bạn chưa có hợp đồng nào đang hiệu lực
  </div>
<% } %>

<%- include('../partials/footer') %>
