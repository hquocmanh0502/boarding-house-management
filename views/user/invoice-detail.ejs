<%- include('../partials/header-user') %>
<div class="page-header">
  <h4><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Hóa đơn tháng <%= invoice.month %>/<%= invoice.year %></h4>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-print me-1"></i>In</button>
    <a href="/user/invoices" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Quay lại</a>
  </div>
</div>

<div class="invoice-box">
  <div class="invoice-header">
    <div>
      <h5 class="fw-bold text-primary mb-1">HÓA ĐƠN TIỀN PHÒNG</h5>
      <div class="text-muted small">Mã: <strong><%= invoice.invoiceCode %></strong></div>
      <div class="text-muted small">Tháng <%= invoice.month %>/<%= invoice.year %></div>
    </div>
    <div class="text-end">
      <div class="fw-bold">Phòng <%= invoice.room?.roomNumber %></div>
      <% if (invoice.isPaid) { %>
        <span class="badge-paid">✓ Đã thanh toán</span>
        <% if (invoice.paidAt) { %>
          <div class="text-muted small mt-1"><%= moment(invoice.paidAt).format('DD/MM/YYYY HH:mm') %></div>
        <% } %>
      <% } else { %>
        <span class="badge-unpaid">⚠ Chưa thanh toán</span>
      <% } %>
    </div>
  </div>

  <table class="table table-sm mb-4">
    <thead><tr><th>Khoản mục</th><th>Chi tiết</th><th class="text-end">Thành tiền</th></tr></thead>
    <tbody>
      <tr>
        <td><i class="fa-solid fa-bolt text-warning me-1"></i>Tiền điện</td>
        <td class="text-muted small"><%= invoice.electricNewIndex %> - <%= invoice.electricOldIndex %> = <strong><%= invoice.electricUsage %> kWh</strong> × <%= invoice.electricPrice.toLocaleString('vi-VN') %>đ</td>
        <td class="text-end"><%= invoice.electricTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-droplet text-primary me-1"></i>Tiền nước</td>
        <td class="text-muted small"><%= invoice.waterNewIndex %> - <%= invoice.waterOldIndex %> = <strong><%= invoice.waterUsage %> m³</strong> × <%= invoice.waterPrice.toLocaleString('vi-VN') %>đ</td>
        <td class="text-end"><%= invoice.waterTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-concierge-bell text-success me-1"></i>Phí dịch vụ</td>
        <td class="text-muted small"><%= invoice.servicePrice.toLocaleString('vi-VN') %>đ × <%= invoice.numOfTenants %> người</td>
        <td class="text-end"><%= invoice.serviceTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-house me-1"></i>Tiền phòng</td>
        <td class="text-muted small">Tháng <%= invoice.month %>/<%= invoice.year %></td>
        <td class="text-end"><%= invoice.rentPrice.toLocaleString('vi-VN') %>đ</td>
      </tr>
    </tbody>
  </table>

  <div class="invoice-total mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <span class="fw-semibold">TỔNG CỘNG PHẢI THANH TOÁN</span>
      <span class="fs-4 fw-bold"><%= invoice.totalAmount.toLocaleString('vi-VN') %>đ</span>
    </div>
  </div>

  <% if (!invoice.isPaid) { %>
  <!-- Thanh toán PayOS -->
  <div class="p-4 rounded-3 mb-3" style="background: linear-gradient(135deg, #667eea15, #764ba215); border: 1px solid #667eea30;">
    <div class="d-flex align-items-center gap-3 mb-3">
      <img src="https://payos.vn/wp-content/uploads/sites/13/2023/07/payos-logo.png" alt="PayOS" height="28" onerror="this.style.display='none'">
      <div>
        <h6 class="mb-0 fw-bold">Thanh toán trực tuyến qua PayOS</h6>
        <div class="text-muted small">Hỗ trợ: ATM nội địa, Visa/Master, VietQR, ví điện tử</div>
      </div>
    </div>
    <form action="/user/invoices/<%= invoice._id %>/pay" method="POST">
      <button type="submit" class="btn btn-lg w-100 fw-bold text-white"
        style="background: linear-gradient(135deg, #667eea, #764ba2); border: none; border-radius: 12px; padding: 14px;">
        <i class="fa-solid fa-credit-card me-2"></i>
        Thanh toán <%= invoice.totalAmount.toLocaleString('vi-VN') %>đ qua PayOS
      </button>
    </form>
    <div class="text-center mt-2">
      <small class="text-muted"><i class="fa-solid fa-shield-halved me-1 text-success"></i>Thanh toán an toàn, được mã hoá SSL</small>
    </div>
  </div>

  <% } else { %>
  <!-- Đã thanh toán -->
  <div class="text-center p-4 rounded-3" style="background: #f0fdf4; border: 1px solid #86efac;">
    <i class="fa-solid fa-circle-check fa-2x text-success mb-2 d-block"></i>
    <div class="fw-bold text-success">Hóa đơn đã được thanh toán</div>
    <% if (invoice.note) { %><div class="text-muted small mt-1"><%= invoice.note %></div><% } %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
