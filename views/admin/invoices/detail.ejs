<%- include('../../partials/header-admin') %>
<div class="page-header">
  <h4><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Chi tiết hóa đơn</h4>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary"><i class="fa-solid fa-print me-1"></i> In</button>
    <a href="/admin/invoices" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
  </div>
</div>

<div class="invoice-box">
  <div class="invoice-header">
    <div>
      <h4 class="fw-bold text-primary mb-1">HÓA ĐƠN TIỀN PHÒNG</h4>
      <p class="text-muted small mb-0">Mã: <strong><%= invoice.invoiceCode %></strong></p>
      <p class="text-muted small mb-0">Tháng <%= invoice.month %>/<%= invoice.year %></p>
    </div>
    <div class="text-end">
      <div class="fw-bold fs-5">Phòng <%= invoice.room?.roomNumber %></div>
      <% if (invoice.isPaid) { %><span class="badge-paid">✓ Đã thanh toán</span>
      <% } else { %><span class="badge-unpaid">⚠ Chưa thanh toán</span><% } %>
    </div>
  </div>

  <!-- Chi tiết -->
  <table class="table table-sm mb-4">
    <thead><tr><th>Khoản mục</th><th>Chi tiết</th><th class="text-end">Thành tiền</th></tr></thead>
    <tbody>
      <tr>
        <td><i class="fa-solid fa-bolt text-warning me-1"></i>Tiền điện</td>
        <td class="text-muted small">
          <%= invoice.electricNewIndex %> - <%= invoice.electricOldIndex %> = <strong><%= invoice.electricUsage %> kWh</strong>
          × <%= invoice.electricPrice.toLocaleString('vi-VN') %>đ
        </td>
        <td class="text-end fw-semibold"><%= invoice.electricTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-droplet text-primary me-1"></i>Tiền nước</td>
        <td class="text-muted small">
          <%= invoice.waterNewIndex %> - <%= invoice.waterOldIndex %> = <strong><%= invoice.waterUsage %> m³</strong>
          × <%= invoice.waterPrice.toLocaleString('vi-VN') %>đ
        </td>
        <td class="text-end fw-semibold"><%= invoice.waterTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-concierge-bell text-success me-1"></i>Phí dịch vụ</td>
        <td class="text-muted small">
          <%= invoice.servicePrice.toLocaleString('vi-VN') %>đ × <%= invoice.numOfTenants %> người
        </td>
        <td class="text-end fw-semibold"><%= invoice.serviceTotal.toLocaleString('vi-VN') %>đ</td>
      </tr>
      <tr>
        <td><i class="fa-solid fa-house me-1 text-purple"></i>Tiền thuê phòng</td>
        <td class="text-muted small">Tháng <%= invoice.month %>/<%= invoice.year %></td>
        <td class="text-end fw-semibold"><%= invoice.rentPrice.toLocaleString('vi-VN') %>đ</td>
      </tr>
    </tbody>
  </table>

  <div class="invoice-total">
    <div class="d-flex justify-content-between align-items-center">
      <span class="fw-semibold">TỔNG CỘNG PHẢI THANH TOÁN</span>
      <span class="fs-4 fw-bold"><%= invoice.totalAmount.toLocaleString('vi-VN') %>đ</span>
    </div>
  </div>

  <% if (settings.bankAccount) { %>
  <div class="mt-4 p-3 bg-light rounded-3">
    <h6 class="fw-bold mb-2"><i class="fa-solid fa-building-columns me-2"></i>Thông tin chuyển khoản</h6>
    <div class="small">
      <div><strong>Ngân hàng:</strong> <%= settings.bankName %></div>
      <div><strong>Số TK:</strong> <code class="fs-6"><%= settings.bankAccount %></code></div>
      <div><strong>Chủ TK:</strong> <%= settings.bankOwner %></div>
      <div><strong>Nội dung CK:</strong> <code>P<%= invoice.room?.roomNumber %> T<%= invoice.month %>/<%= invoice.year %></code></div>
    </div>
  </div>
  <% } %>

  <% if (!invoice.isPaid) { %>
  <form action="/admin/invoices/<%= invoice._id %>/pay" method="POST" class="mt-3">
    <button class="btn btn-success w-100"><i class="fa-solid fa-check me-2"></i>Xác nhận đã thanh toán</button>
  </form>
  <% } else { %>
  <div class="alert alert-success mt-3 small text-center">
    <i class="fa-solid fa-circle-check me-1"></i>Đã thanh toán lúc <%= moment(invoice.paidAt).format('HH:mm DD/MM/YYYY') %>
  </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>
