<%- include('../../partials/header-admin') %>
<div class="page-header">
  <h4><i class="fa-solid fa-pen me-2 text-primary"></i>Sửa Phòng <%= room.roomNumber %></h4>
  <a href="/admin/rooms" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
</div>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body p-4">
        <form action="/admin/rooms/<%= room._id %>/edit" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Số phòng</label>
              <input type="text" name="roomNumber" class="form-control" value="<%= room.roomNumber %>" required/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Tầng</label>
              <input type="number" name="floor" class="form-control" value="<%= room.floor %>"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Diện tích (m²)</label>
              <input type="number" name="area" class="form-control" value="<%= room.area %>"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Giá thuê (đ/tháng)</label>
              <input type="number" name="rentPrice" class="form-control" value="<%= room.rentPrice %>" required/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Số người tối đa</label>
              <input type="number" name="maxOccupants" class="form-control" value="<%= room.maxOccupants %>"/>
            </div>
            <div class="col-md-6">
              <label class="form-label">Trạng thái</label>
              <select name="status" class="form-select">
                <option value="available" <%= room.status==='available'?'selected':'' %>>Còn trống</option>
                <option value="occupied" <%= room.status==='occupied'?'selected':'' %>>Đang có người</option>
                <option value="maintenance" <%= room.status==='maintenance'?'selected':'' %>>Bảo trì</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label">Tiện nghi có sẵn</label>
              <div class="d-flex flex-wrap gap-3 mt-1">
                <% const standardAmenities = ['fridge','ac','wardrobe','bed','wifi','wc','kitchen','parking'];
                   const standardLabels = {fridge:'Tủ lạnh',ac:'Điều hòa',wardrobe:'Tủ quần áo',bed:'Giường',wifi:'Wifi',wc:'WC riêng',kitchen:'Bếp',parking:'Gửi xe'};
                   const standardIcons  = {fridge:'fa-temperature-low',ac:'fa-snowflake',wardrobe:'fa-shirt',bed:'fa-bed',wifi:'fa-wifi',wc:'fa-shower',kitchen:'fa-fire-burner',parking:'fa-motorcycle'};
                   standardAmenities.forEach(val => { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="amenities" value="<%= val %>"
                      id="am_<%= val %>" <%= room.amenities && room.amenities.includes(val) ? 'checked' : '' %>/>
                    <label class="form-check-label" for="am_<%= val %>">
                      <i class="fa-solid <%= standardIcons[val] %> me-1"></i><%= standardLabels[val] %>
                    </label>
                  </div>
                <% }) %>
              </div>
            </div>
            <!-- Custom amenities -->
            <div class="col-12">
              <label class="form-label">Tiện nghi khác (tùy chỉnh)</label>
              <div class="d-flex gap-2 mb-2">
                <input type="text" id="customAmenityInput" class="form-control" placeholder="VD: Máy giặt, Ban công..."/>
                <button type="button" class="btn btn-outline-primary px-3" onclick="addCustomAmenity()">
                  <i class="fa-solid fa-plus"></i>
                </button>
              </div>
              <div id="customAmenityTags" class="d-flex flex-wrap gap-2">
                <% (room.amenities || []).filter(a => !standardAmenities.includes(a)).forEach(a => { %>
                  <div class="d-flex align-items-center gap-1 px-3 py-1 rounded-pill border bg-white" style="font-size:13px">
                    <i class="fa-solid fa-tag text-primary" style="font-size:11px"></i>
                    <span><%= a %></span>
                    <input type="hidden" name="amenities" value="<%= a %>"/>
                    <button type="button" class="btn-close ms-1" style="font-size:9px" onclick="this.parentElement.remove()"></button>
                  </div>
                <% }) %>
              </div>
            </div>
            <div class="col-12">
              <label class="form-label">Mô tả</label>
              <textarea name="description" class="form-control" rows="3"><%= room.description || '' %></textarea>
            </div>
          </div>
          <div class="d-grid mt-4">
            <button type="submit" class="btn btn-primary py-2">
              <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thay đổi
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>

<script>
function addCustomAmenity() {
  const input = document.getElementById('customAmenityInput');
  const val = input.value.trim();
  if (!val) return;
  const container = document.getElementById('customAmenityTags');
  const tag = document.createElement('div');
  tag.className = 'd-flex align-items-center gap-1 px-3 py-1 rounded-pill border bg-white';
  tag.style.fontSize = '13px';
  tag.innerHTML = `
    <i class="fa-solid fa-tag text-primary" style="font-size:11px"></i>
    <span>${val}</span>
    <input type="hidden" name="amenities" value="${val}"/>
    <button type="button" class="btn-close ms-1" style="font-size:9px" onclick="this.parentElement.remove()"></button>
  `;
  container.appendChild(tag);
  input.value = '';
  input.focus();
}
document.getElementById('customAmenityInput')?.addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); addCustomAmenity(); }
});
</script>
