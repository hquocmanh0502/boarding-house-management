<%- include('../../partials/header-admin') %>
<div class="page-header">
  <h4><i class="fa-solid fa-file-contract me-2 text-primary"></i>Hợp đồng <%= contract.contractCode %></h4>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary"><i class="fa-solid fa-print me-1"></i> In</button>
    <a href="/admin/contracts" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại</a>
  </div>
</div>

<div class="invoice-box">
  <div class="text-center mb-4">
    <h4 class="fw-bold">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM</h4>
    <p class="text-muted">Độc lập - Tự do - Hạnh phúc</p>
    <h5 class="fw-bold mt-3">HỢP ĐỒNG THUÊ NHÀ TRỌ</h5>
    <p class="text-muted">Mã hợp đồng: <strong><%= contract.contractCode %></strong></p>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-user-tie me-2"></i>BÊN CHO THUÊ (A)</h6>
      <div class="small"><strong>Tên:</strong> <%= settings.landlordName || 'Chủ nhà' %></div>
      <div class="small"><strong>SĐT:</strong> <%= settings.landlordPhone || '—' %></div>
      <div class="small"><strong>Địa chỉ:</strong> <%= settings.address || '—' %></div>
    </div>
    <div class="col-md-6">
      <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-user me-2"></i>BÊN THUÊ (B)</h6>
      <div class="small"><strong>Họ tên:</strong> <%= contract.user?.fullName %></div>
      <div class="small"><strong>SĐT:</strong> <%= contract.user?.phone || '—' %></div>
      <div class="small"><strong>CCCD:</strong> <%= contract.user?.idCard || '—' %></div>
    </div>
  </div>

  <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-door-open me-2"></i>THÔNG TIN PHÒNG</h6>
  <div class="row g-2 small mb-4">
    <div class="col-6"><strong>Phòng số:</strong> <%= contract.room?.roomNumber %></div>
    <div class="col-6"><strong>Giá thuê:</strong> <%= contract.rentPrice.toLocaleString('vi-VN') %>đ/tháng</div>
    <div class="col-6"><strong>Ngày bắt đầu:</strong> <%= moment(contract.startDate).format('DD/MM/YYYY') %></div>
    <div class="col-6"><strong>Ngày kết thúc:</strong> <%= contract.endDate ? moment(contract.endDate).format('DD/MM/YYYY') : 'Không xác định' %></div>
    <div class="col-6"><strong>Tiền cọc:</strong> <%= contract.depositAmount.toLocaleString('vi-VN') %>đ</div>
    <div class="col-6"><strong>Trạng thái:</strong> <span class="badge-<%= contract.status %>">
      <%= contract.status === 'active' ? 'Đang hiệu lực' : contract.status === 'expired' ? 'Hết hạn' : 'Đã chấm dứt' %>
    </span></div>
  </div>

  <% if (contract.terms) { %>
  <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-list-check me-2"></i>ĐIỀU KHOẢN</h6>
  <p class="small" style="white-space:pre-wrap"><%= contract.terms %></p>
  <% } %>

  <% if (contract.status === 'active') { %>
  <form action="/admin/contracts/<%= contract._id %>/terminate" method="POST" class="mt-4"
    onsubmit="return confirm('Xác nhận chấm dứt hợp đồng này?')">
    <button class="btn btn-outline-danger">
      <i class="fa-solid fa-ban me-2"></i>Chấm dứt hợp đồng
    </button>
  </form>
  <% } %>
</div>

<%- include('../../partials/footer') %>
