<%- include('../../partials/header-admin') %>
<div class="page-header">
  <h4><i class="fa-solid fa-bell me-2 text-primary"></i>Quản lý thông báo</h4>
  <a href="/admin/notifications/create" class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i> Gửi thông báo</a>
</div>

<div class="row g-3">
<% notifications.forEach(n => { %>
  <div class="col-12">
    <div class="card">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start">
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-1">
              <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:11px;border-radius:6px;">
                <%= n.type === 'general' ? 'Chung' : n.type === 'invoice' ? 'Hóa đơn' : n.type === 'maintenance' ? 'Sửa chữa' : 'Khác' %>
              </span>
              <span class="text-muted small"><%= new Date(n.createdAt).toLocaleString('vi-VN') %></span>
              <% if (n.targetRooms && n.targetRooms.length > 0) { %>
                <span class="badge bg-warning bg-opacity-10 text-warning" style="font-size:11px;border-radius:6px;">
                  Phòng: <%= n.targetRooms.map(r => r.roomNumber).join(', ') %>
                </span>
              <% } else { %>
                <span class="badge bg-success bg-opacity-10 text-success" style="font-size:11px;border-radius:6px;">Tất cả</span>
              <% } %>
            </div>
            <h6 class="fw-bold mb-1"><%= n.title %></h6>
            <p class="text-muted small mb-0"><%= n.content %></p>
          </div>
          <form action="/admin/notifications/<%= n._id %>/delete" method="POST"
            onsubmit="return confirm('Xóa thông báo này?')" class="ms-3">
            <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
<% }) %>
<% if (notifications.length === 0) { %>
  <div class="col-12 text-center py-5 text-muted">
    <i class="fa-solid fa-bell-slash fa-3x mb-3 d-block opacity-25"></i>Chưa có thông báo nào
  </div>
<% } %>
</div>

<%- include('../../partials/footer') %>
